{
  "name": "@rafters/kelex",
  "version": "0.1.2",
  "description": "Generate forms from Zod schemas with pluggable targets",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rafters-studio/kelex.git"
  },
  "homepage": "https://rafters.studio/tools/kelex",
  "keywords": [
    "zod",
    "form",
    "codegen",
    "typescript",
    "rafters"
  ],
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kelex": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/*.spec.ts'",
    "test:unit": "vitest run --exclude '**/*.spec.ts'",
    "test:spec": "vitest run test/cli.spec.ts test/stress/stress.spec.ts",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src test",
    "lint:fix": "oxlint --fix src test",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "preflight": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "flightcheck": "pnpm lint && pnpm typecheck && pnpm test:all",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.0.9",
    "lefthook": "^2.0.15",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook",
      "esbuild",
      "rolldown"
    ]
  }
}
